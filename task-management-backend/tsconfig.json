{
  "compilerOptions": {
    "module": "Node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "Node16",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src", "prisma"]
}
